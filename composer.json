{
    "name": "hackthebox/laravel-iam-auth",
    "description": "AWS IAM authentication for Laravel: RDS database connections and SDK credential caching for PHP-FPM",
    "keywords": ["laravel", "aws", "iam", "rds", "authentication", "eks", "pod-identity", "credential-caching"],
    "license": "MIT",
    "type": "library",
    "require": {
        "aws/aws-sdk-php": "^3.249",
        "aws/aws-sdk-php-laravel": "^3.7",
        "ext-pdo": "*",
        "php": "^8.2",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.0|^10.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "ext-apcu": "Recommended for caching IAM auth tokens and AWS credentials between PHP-FPM requests"
    },
    "autoload": {
        "psr-4": {
            "Hackthebox\\IamAuth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hackthebox\\IamAuth\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hackthebox\\IamAuth\\IamAuthServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
